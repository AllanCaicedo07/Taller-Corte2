{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "copy demo dependencies",
            "type": "shell",
            "command": "mvn",
            "args": [
                "-f",
                "${workspaceFolder}/demo/pom.xml",
                "dependency:copy-dependencies",
                "-DoutputDirectory=${workspaceFolder}/demo/target/dependency"
            ],
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "problemMatcher": []
        }
    ]
}
